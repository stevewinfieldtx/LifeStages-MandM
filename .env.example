# ============================================================
# The Meaningful Message — Environment Variables
# ============================================================
# Copy this file to .env.local for local dev.
# On Railway, set these in each service's Variables tab.

# --- LLM (required) ---
# Steve's standard for all LifeStages / WinTech projects
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL_ID=openai/gpt-4.1-mini

# --- Database (required for workers + dashboard) ---
# On Railway: reference as ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/railway

# --- App metadata ---
NEXT_PUBLIC_APP_NAME=The Meaningful Message
APP_URL=http://localhost:3000

# --- Reviewer notifications (optional for MVP) ---
# Resend is the easiest; swap for Postmark/SES later if needed
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
REVIEW_FROM_EMAIL=mm@yourdomain.com

# --- Seed script defaults ---
SEED_REVIEWER_EMAIL=stevewinfieldtx@gmail.com
# Get Fielder's channel ID by viewing page source at https://www.youtube.com/@FielderChurch
# and searching for "channelId":"UC..."
SEED_YT_CHANNEL_ID=
