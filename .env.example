# ============================================================
# The Meaningful Message — Environment Variables
# ============================================================
# Copy this file to .env.local for local dev.
# On Railway, set these in each service's Variables tab.

# --- LLM (required) ---
# Steve's standard for all LifeStages / WinTech projects
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL_ID=openai/gpt-4.1-mini

# --- Database (required for workers + dashboard) ---
# On Railway: reference as ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/railway

# --- App metadata ---
NEXT_PUBLIC_APP_NAME=The Meaningful Message
APP_URL=http://localhost:3000

# --- Reviewer notifications (optional for MVP) ---
# Resend is the easiest; swap for Postmark/SES later if needed
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
REVIEW_FROM_EMAIL=mm@yourdomain.com

# --- Inbound transcripts (required so TDE can push) ---
# Shared secret. Set this on M&M's web service AND on TDE as
# MANDM_INGEST_TOKEN. Generate one with: openssl rand -hex 32
INGEST_TOKEN=

# --- Video rendering (required for renderer worker) ---
# ElevenLabs API key — TTS for the rendered video narration.
# Get one at https://elevenlabs.io/api
ELEVENLABS_API_KEY=
# Default voice if the user doesn't pick one in the UI.
# Rachel: 21m00Tcm4TlvDq8ikWAM | Adam: pNInz6obpgDQGcFmaJgB
# Bella: EXAVITQu4vr4xnSDxMaL | Antoni: ErXwobaYiN019PkySvjV
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ElevenLabs model. eleven_turbo_v2_5 is fastest + cheapest;
# eleven_multilingual_v2 if you need non-English.
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Where rendered MP4s live on disk. On Railway: mount a Volume here.
# Locally falls back to ./data if unset.
RENDER_DATA_DIR=

# --- Seed script defaults ---
SEED_REVIEWER_EMAIL=stevewinfieldtx@gmail.com
# Get Fielder's channel ID by viewing page source at https://www.youtube.com/@FielderChurch
# and searching for "channelId":"UC..."
SEED_YT_CHANNEL_ID=
