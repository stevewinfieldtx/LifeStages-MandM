{
  "name": "lifestages-mandm",
  "version": "0.3.0",
  "private": true,
  "description": "The Meaningful Message — turn a church's Sunday sermon into a 10-minute YouTube-native digital discipleship asset. Fully automated: Railway + Postgres + OpenRouter.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:workers": "tsc -p tsconfig.workers.json",
    "worker:watcher": "node dist/workers/watcher/index.js",
    "worker:generator": "node dist/workers/generator/index.js",
    "worker:renderer": "node dist/workers/renderer/index.js",
    "dev:watcher": "tsx workers/watcher/index.ts",
    "dev:generator": "tsx workers/generator/index.ts",
    "dev:renderer": "tsx workers/renderer/index.ts",
    "seed:fielder": "tsx scripts/seed-fielder.ts",
    "db:init": "tsx scripts/init-db.ts",
    "check": "node --check next.config.js && echo 'syntax ok'"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.56",
    "ffmpeg-static": "5.2.0",
    "fluent-ffmpeg": "2.1.3",
    "next": "^16.2.4",
    "pg": "8.13.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "2.1.27",
    "@types/node": "22.14.0",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "tsx": "4.19.2",
    "typescript": "5.8.3"
  }
}
